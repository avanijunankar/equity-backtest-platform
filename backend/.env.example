# Database mode (Docker PostgreSQL)
USE_DATABASE=true
DATABASE_URL=postgresql://backtest_user:backtest_pass@localhost:5432/equity_backtest
DATABASE_CONNECT_TIMEOUT=5

# Cloud PostgreSQL (Neon/Supabase) — replace DATABASE_URL:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/equity_backtest?sslmode=require

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
